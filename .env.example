# CLASH runtime settings

# Optional: frontend socket endpoint override
VITE_CLASH_SERVER=http://localhost:8787

# LIVE AI mode (OpenAI-compatible)
# For Groq use: https://api.groq.com/openai/v1
CLASH_LLM_API_KEY=your_provider_api_key_here
CLASH_LLM_MODEL=llama-3.3-70b-versatile
CLASH_LLM_BASE_URL=https://api.groq.com/openai/v1
CLASH_LLM_TIMEOUT_MS=16000
CLASH_LLM_MAX_RETRIES=2
CLASH_LLM_BREAKER_COOLDOWN_MS=45000
